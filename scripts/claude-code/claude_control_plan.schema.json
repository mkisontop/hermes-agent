{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "route",
    "decision",
    "confidence",
    "skills_to_use",
    "next_profile",
    "requires_user_confirmation",
    "response"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "route": {
      "type": "string",
      "enum": ["planning", "coding", "review", "normal"]
    },
    "decision": {
      "type": "string",
      "enum": [
        "answer",
        "ask_clarifying",
        "use_skill",
        "delegate_plan",
        "delegate_patch",
        "delegate_review",
        "refuse"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "reasoning_summary": {
      "type": "string",
      "maxLength": 1200
    },
    "skills_to_use": {
      "type": "array",
      "items": { "type": "string" },
      "maxItems": 5
    },
    "next_profile": {
      "type": "string",
      "enum": [
        "none",
        "plan_minimal",
        "plan_files",
        "patch_worktree",
        "review"
      ]
    },
    "requires_user_confirmation": {
      "type": "boolean"
    },
    "confirmation_prompt": {
      "type": ["string", "null"]
    },
    "response": {
      "type": ["string", "null"]
    }
  }
}
